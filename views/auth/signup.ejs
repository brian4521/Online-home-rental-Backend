<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up</title>

  <link rel="stylesheet" href="/home.css">
  <link rel="stylesheet" href="/output.css">
  <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gradient-to-br from-blue-100 via-white to-blue-200">

  <%- include('../partials/navbar') %>

  <div class="flex justify-center items-center min-h-screen px-4">

    <div class="bg-white/90 backdrop-blur-lg shadow-xl rounded-2xl p-8 w-full max-w-md border border-gray-200">

      <!-- Title -->
      <h1 class="text-2xl font-bold text-center text-gray-800 mb-2">
        Create Account
      </h1>
      <p class="text-sm text-gray-500 text-center mb-6">
        Join us and start your journey 🚀
      </p>

      <!-- Form -->
      <form action="/signup" method="POST" class="space-y-4" autocomplete="off">
           <!-- error message -->
         <%- include('../partials/errorsection') %>
        <!-- Name Fields -->
        <div class="flex gap-3">



       
          <input 
            type="text" 
            name="firstName" 
            value="<%= oldInput ? oldInput.firstName : '' %>"
            placeholder="First Name"
            class="w-1/2 p-2.5 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400 transition"
          />
          <input 
            type="text" 
            name="lastName" 
            value="<%= oldInput ? oldInput.lastName : '' %>"
            placeholder="Last Name"
            class="w-1/2 p-2.5 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400 transition"
          />
        </div>

        <!-- Email -->
        <input 
          type="email" 
          name="email" 
          value="<%= oldInput ? oldInput.email : '' %>"
          placeholder="Email address"
          required
          class="w-full p-2.5 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400 transition"
        />

        <!-- Password -->
        <input 
          type="password" 
          name="password"  
          value="<%= oldInput ? oldInput.password : '' %>"
          placeholder="Password"
          required
          class="w-full p-2.5 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400 transition"
        />

        <input 
          type="password" 
          name="confirmPassword"  
          placeholder="Confirm Password"
          required
          class="w-full p-2.5 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400 transition"
        />

        <!-- User Type -->
        <div>
          <p class="text-sm font-medium text-gray-700 mb-2">User Type</p>
          <div class="flex gap-6 text-sm text-gray-600">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="userType" value="guest" class="accent-blue-500" checked="<% oldInput.userType === 'guest' %>" >
              Guest
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="userType" value="host" class="accent-blue-500" checked="<% oldInput.userType === 'host' %>" >
              Host
            </label>
          </div>
        </div>

        <!-- Terms -->
        <div class="flex items-center gap-2 text-sm text-gray-600">
          <input type="checkbox" id="policies" name="policies" class="accent-blue-500">
          <label for="policies">I agree to Terms & Conditions</label>
        </div>

        <!-- Button -->
        <button 
          type="submit"
          class="w-full bg-gradient-to-r from-blue-500 to-blue-600 text-white py-2.5 rounded-lg font-medium hover:from-blue-600 hover:to-blue-700 transition duration-200 shadow-md"
        >
          Sign Up
        </button>

      </form>

      <!-- Footer -->
      <p class="text-sm text-center text-gray-500 mt-5">
        Already have an account?
        <a href="/login" class="text-blue-600 hover:underline font-medium">Login</a>
      </p>

    </div>

  </div>

</body>
</html>