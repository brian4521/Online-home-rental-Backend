<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
  <link rel="stylesheet" href="home.css">
  <link rel="stylesheet" href="output.css">
</head>
<body>
  <script src="https://cdn.tailwindcss.com"></script>
  <%- include('../partials/navbar') %>

  <header>
  
    <div class="p-6">
      <center>
          <h1 class="text-3xl font-bold mb-6">Welcome to Favourite list</h1>


      </center>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
    <% allFavouriteList.forEach((home) => { %>

      <div class="border rounded-lg p-4 shadow">

        <img 
          src="<%= home.photoUrl %>" 
          alt="house image"
          class="w-full h-40 object-cover rounded mb-3"
        >

        <h2 class="text-xl font-semibold">
          <%= home.house %>
        </h2>

        <p class="text-gray-600">
          Location: <%= home.location %>
        </p>

        <p class="text-gray-600">
          Price: $<%= home.price %>
        </p>

        <p class="text-gray-600">
          Rating: ⭐ <%= home.rating %>
        </p>
        <div class="mt-3">
           <a href="/home/<%= home.id %>" class="bg-blue-500 px-4 py-2 rounded hover:bg-yellow-600">Details</a>
           <div class="mt-3">
              <form action="/favouritedelete/<%= home._id %>" method="post">
                 <button type="submit" class="bg-red-500 px-4 py-2 rounded">Delete</button>

               </form>

           </div>


        

        </div>
         
         

      </div>

    <% }) %>

  </div>
</div>

  </header>
,
  <!-- <main>
    <a href="/host/home">Home</a>

  </main> -->
    
  
</body>
</html>